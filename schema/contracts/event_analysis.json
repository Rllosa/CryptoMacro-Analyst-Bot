{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cryptomacro.local/schemas/event_analysis.json",
  "title": "Event Analysis",
  "description": "Schema for event-triggered LLM analysis (HIGH severity alerts only)",
  "type": "object",
  "required": [
    "report_id",
    "report_type",
    "generated_at",
    "trigger_alert",
    "context",
    "analysis",
    "llm_metadata"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "description": "Unique report identifier (UUID)",
      "format": "uuid"
    },
    "report_type": {
      "type": "string",
      "description": "Type of report",
      "enum": ["event_analysis"],
      "const": "event_analysis"
    },
    "generated_at": {
      "type": "string",
      "description": "Report generation timestamp in ISO 8601 UTC format",
      "format": "date-time"
    },
    "trigger_alert": {
      "type": "object",
      "description": "The HIGH severity alert that triggered this analysis",
      "required": ["alert_id", "alert_type", "symbol", "severity", "time"],
      "properties": {
        "alert_id": {"type": "string", "format": "uuid"},
        "alert_type": {"type": "string"},
        "symbol": {"type": ["string", "null"]},
        "severity": {"type": "string", "enum": ["HIGH"]},
        "time": {"type": "string", "format": "date-time"},
        "conditions": {"type": "object"}
      }
    },
    "context": {
      "type": "object",
      "description": "Market context at time of alert",
      "required": ["regime", "recent_alerts"],
      "properties": {
        "regime": {
          "type": "object",
          "properties": {
            "current": {"type": "string"},
            "confidence": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "recent_alerts": {
          "type": "array",
          "description": "Alerts in the last 4 hours",
          "items": {
            "type": "object",
            "properties": {
              "alert_type": {"type": "string"},
              "symbol": {"type": ["string", "null"]},
              "time": {"type": "string", "format": "date-time"}
            }
          }
        },
        "features": {
          "type": "object",
          "description": "Relevant computed features at alert time",
          "additionalProperties": true
        },
        "price_context": {
          "type": "object",
          "description": "Price action context",
          "properties": {
            "current_price": {"type": "number"},
            "r_4h": {"type": "number"},
            "r_24h": {"type": "number"}
          }
        }
      }
    },
    "analysis": {
      "type": "object",
      "description": "LLM analysis output",
      "required": ["summary", "interpretation", "watch_next"],
      "properties": {
        "summary": {
          "type": "string",
          "description": "1-2 sentence summary of the event",
          "minLength": 10
        },
        "interpretation": {
          "type": "string",
          "description": "Detailed interpretation of what this alert means",
          "minLength": 50
        },
        "watch_next": {
          "type": "array",
          "description": "Key levels or conditions to monitor",
          "items": {"type": "string"},
          "minItems": 1,
          "maxItems": 5
        },
        "similar_historical_events": {
          "type": "array",
          "description": "References to similar past events if applicable",
          "items": {"type": "string"}
        }
      }
    },
    "llm_metadata": {
      "type": "object",
      "description": "LLM generation metadata",
      "required": ["model", "tokens_used", "cost_usd"],
      "properties": {
        "model": {"type": "string"},
        "tokens_used": {"type": "integer", "minimum": 0},
        "cost_usd": {"type": "number", "minimum": 0},
        "generation_time_ms": {"type": "integer", "minimum": 0}
      }
    }
  },
  "additionalProperties": false
}
