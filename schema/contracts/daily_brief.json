{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cryptomacro.local/schemas/daily_brief.json",
  "title": "Daily Brief",
  "description": "Schema for daily brief analysis generated 2x per day (9 AM + 7 PM Dubai)",
  "type": "object",
  "required": [
    "report_id",
    "report_type",
    "generated_at",
    "time_range",
    "regime_summary",
    "alert_summary",
    "market_summary",
    "key_insights",
    "watch_list",
    "llm_metadata"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "description": "Unique report identifier (UUID)",
      "format": "uuid"
    },
    "report_type": {
      "type": "string",
      "description": "Type of report",
      "enum": ["daily_brief"],
      "const": "daily_brief"
    },
    "generated_at": {
      "type": "string",
      "description": "Report generation timestamp in ISO 8601 UTC format",
      "format": "date-time"
    },
    "time_range": {
      "type": "object",
      "description": "Time range covered by this brief",
      "required": ["start", "end"],
      "properties": {
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "regime_summary": {
      "type": "object",
      "description": "Current regime state and recent transitions",
      "required": ["current_regime", "confidence"],
      "properties": {
        "current_regime": {
          "type": "string",
          "enum": ["RISK_ON_TREND", "RISK_OFF_STRESS", "CHOP_RANGE", "VOL_EXPANSION", "DELEVERAGING"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "transitions": {
          "type": "array",
          "description": "Recent regime transitions in the time window",
          "items": {
            "type": "object",
            "required": ["time", "from_regime", "to_regime"],
            "properties": {
              "time": {"type": "string", "format": "date-time"},
              "from_regime": {"type": "string"},
              "to_regime": {"type": "string"}
            }
          }
        },
        "analysis": {
          "type": "string",
          "description": "LLM analysis of regime context"
        }
      }
    },
    "alert_summary": {
      "type": "object",
      "description": "Summary of alerts fired in time window",
      "required": ["total_alerts", "by_type", "by_severity"],
      "properties": {
        "total_alerts": {
          "type": "integer",
          "minimum": 0
        },
        "by_type": {
          "type": "object",
          "additionalProperties": {"type": "integer"}
        },
        "by_severity": {
          "type": "object",
          "properties": {
            "HIGH": {"type": "integer"},
            "MEDIUM": {"type": "integer"},
            "LOW": {"type": "integer"}
          }
        },
        "notable_alerts": {
          "type": "array",
          "description": "Most significant alerts with context",
          "items": {
            "type": "object",
            "required": ["alert_id", "alert_type", "symbol", "severity"],
            "properties": {
              "alert_id": {"type": "string", "format": "uuid"},
              "alert_type": {"type": "string"},
              "symbol": {"type": ["string", "null"]},
              "severity": {"type": "string"},
              "summary": {"type": "string"}
            }
          }
        }
      }
    },
    "market_summary": {
      "type": "object",
      "description": "Market performance summary for BTC, ETH, SOL, HYPE",
      "required": ["assets"],
      "properties": {
        "assets": {
          "type": "object",
          "description": "Per-asset performance",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "price_change_pct": {"type": "number"},
              "volume_change_pct": {"type": "number"},
              "volatility_regime": {"type": "string", "enum": ["low", "medium", "high"]}
            }
          }
        },
        "correlations": {
          "type": "object",
          "description": "Key correlation observations",
          "properties": {
            "btc_spx": {"type": "number", "minimum": -1, "maximum": 1},
            "btc_dxy": {"type": "number", "minimum": -1, "maximum": 1}
          }
        }
      }
    },
    "key_insights": {
      "type": "array",
      "description": "Bullet-point key insights from LLM analysis",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 5
    },
    "watch_list": {
      "type": "array",
      "description": "Key levels, conditions, or events to watch",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "maxItems": 5
    },
    "llm_metadata": {
      "type": "object",
      "description": "LLM generation metadata",
      "required": ["model", "tokens_used", "cost_usd"],
      "properties": {
        "model": {
          "type": "string",
          "examples": ["claude-sonnet-4-5-20250929"]
        },
        "tokens_used": {
          "type": "integer",
          "minimum": 0
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "generation_time_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "additionalProperties": false
}
