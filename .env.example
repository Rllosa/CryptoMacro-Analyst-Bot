# CryptoMacro Analyst Bot - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it contains secrets

# =============================================================================
# Database Configuration (TimescaleDB / PostgreSQL)
# =============================================================================
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=cryptomacro
POSTGRES_USER=cryptomacro
POSTGRES_PASSWORD=cryptomacro_dev_password  # CHANGE IN PRODUCTION

# Database connection string (constructed from above)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# =============================================================================
# NATS JetStream Configuration
# =============================================================================
NATS_URL=nats://nats:4222
NATS_MONITORING_URL=http://nats:8222

# =============================================================================
# External API Keys
# =============================================================================

# Binance (no key needed for public WebSocket streams)
# BINANCE_API_KEY=  # Optional, only if using authenticated endpoints
# BINANCE_API_SECRET=  # Optional, only if using authenticated endpoints

# Coinglass API (for derivatives data)
COINGLASS_API_KEY=your_coinglass_api_key_here

# FRED API (for macro economic data)
FRED_API_KEY=your_fred_api_key_here

# Yahoo Finance (no key needed for free tier)
# No configuration required

# On-Chain Provider (CryptoQuant)
# Decision: CryptoQuant for entity-tagged exchange flows (see docs/ONCHAIN_PROVIDER.md)
# Used in Phase 4 for BTC/ETH exchange inflow/outflow/netflow data
CRYPTOQUANT_API_KEY=your_cryptoquant_api_key_here

# =============================================================================
# LLM Configuration (Claude API)
# =============================================================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL_DAILY=claude-sonnet-4.5  # For daily briefs
CLAUDE_MODEL_WEEKLY=claude-opus-4.6   # For weekly deep reports
CLAUDE_MODEL_EVENT=claude-sonnet-4.5  # For event analysis

# =============================================================================
# Discord Bot Configuration
# =============================================================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_SERVER_ID=your_discord_server_id_here

# Discord Channel IDs
DISCORD_CHANNEL_ALERTS_HIGH=your_alerts_high_channel_id_here
DISCORD_CHANNEL_ALERTS_ALL=your_alerts_all_channel_id_here
DISCORD_CHANNEL_DAILY_BRIEF=your_daily_brief_channel_id_here
DISCORD_CHANNEL_REGIME_SHIFTS=your_regime_shifts_channel_id_here
DISCORD_CHANNEL_ONCHAIN=your_onchain_channel_id_here
DISCORD_CHANNEL_BOT_COMMANDS=your_bot_commands_channel_id_here
DISCORD_CHANNEL_SYSTEM_HEALTH=your_system_health_channel_id_here

# =============================================================================
# Service Configuration
# =============================================================================

# Environment
ENVIRONMENT=development  # Options: development, staging, production

# Logging
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # Options: json, text

# Timezone for scheduled tasks
TIMEZONE=Asia/Dubai  # For 9 AM and 7 PM Dubai time briefs

# =============================================================================
# Dashboard Configuration (Phase 6)
# =============================================================================
# API_HOST=0.0.0.0
# API_PORT=8000
# DASHBOARD_URL=http://localhost:3000
# JWT_SECRET=your_jwt_secret_for_dashboard_auth  # Only if exposing publicly

# =============================================================================
# Feature Flags (for gradual rollout)
# =============================================================================
ENABLE_DERIVATIVES_ALERTS=true
ENABLE_ONCHAIN_ALERTS=false  # Enable after F-2 provider decision + DI-6
ENABLE_LLM_BRIEFS=false      # Enable after LLM-3
ENABLE_DASHBOARD=false       # Enable in Phase 6

# =============================================================================
# Monitoring & Observability
# =============================================================================
# SENTRY_DSN=  # Optional: for error tracking
# PROMETHEUS_PORT=9090  # Optional: for metrics export
